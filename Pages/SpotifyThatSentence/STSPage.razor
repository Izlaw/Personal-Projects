@page "/sts"
@inject SpotifyService SpotifyService
@inject AppThemeService AppTheme
@implements IDisposable

<PageTitle>Spotify That Sentence</PageTitle>

<div class="sts-root">
    <div class="sts-hero">
        <div class="sts-logo-row">
            <svg class="sts-spotify-icon" viewBox="0 0 24 24" fill="#1DB954" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
            <span class="sts-title">Spotify that Sentence</span>
        </div>
        <p class="sts-subtitle">Type a sentence and press Enter - every word becomes a Spotify song!</p>

        <div class="sts-search-wrap">
            <input class="sts-input"
                   @bind="_sentence"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   placeholder="Type a sentence and press Enter"
                   disabled="@_isSearching" />

            @if (_isSearching)
            {
                <div class="sts-result-box">
                    <p class="sts-searching">🔍 Searching...</p>
                </div>
            }
            else if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="sts-result-box">
                    <p class="sts-error-msg">@_errorMessage</p>
                </div>
            }
            else if (_results.Count > 0)
            {
                <div class="sts-result-box">
                    <STSResultsComponent Results="_results" />
                </div>
            }
        </div>
    </div>
</div>

<style>
    .sts-root {
        min-height: var(--page-h);
        background: #121212;
        font-family: 'Circular', 'Helvetica Neue', Helvetica, Arial, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sts-hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 16px;
        gap: 4px;
        width: 100%;
    }

    .sts-logo-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .sts-spotify-icon {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
    }

    .sts-title {
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        letter-spacing: -0.5px;
    }

    .sts-subtitle {
        color: #b3b3b3;
        font-size: 0.875rem;
        margin: 0;
        text-align: center;
    }

    .sts-search-wrap {
        width: 100%;
        max-width: 480px;
        margin-top: 16px;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .sts-input {
        width: 100%;
        box-sizing: border-box;
        background: #282828;
        border: none;
        border-radius: 500px;
        padding: 14px 20px;
        color: #fff;
        font-size: 0.95rem;
        outline: none;
        transition: background 0.2s;
    }

    .sts-input:focus {
        background: #333;
        box-shadow: 0 0 0 2px #1DB954;
    }

    .sts-input::placeholder {
        color: #6a6a6a;
    }

    .sts-input:disabled {
        opacity: 0.6;
    }

    .sts-result-box {
        background: #181818;
        border-radius: 8px;
        font-size: 0.875rem;
        box-shadow: 0 4px 24px rgba(0,0,0,.5);
        max-height: 400px;
        overflow-y: auto;
        margin-top: 8px;
        scrollbar-width: thin;
        scrollbar-color: #535353 transparent;
    }

    .sts-result-box::-webkit-scrollbar { width: 6px; }
    .sts-result-box::-webkit-scrollbar-track { background: transparent; }
    .sts-result-box::-webkit-scrollbar-thumb { background: #535353; border-radius: 3px; }

    .sts-searching {
        padding: 12px 16px;
        color: #b3b3b3;
        margin: 0;
        animation: sts-pulse 1.4s ease-in-out infinite;
    }

    @@keyframes sts-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .sts-error-msg {
        padding: 12px 16px;
        color: #ff6b6b;
        margin: 0;
    }
</style>

@code {
    protected override void OnInitialized() => AppTheme.SetTheme("#1DB954", "#000000");
    public void Dispose() => AppTheme.Reset();

    #region Fields
    private string _sentence = "";
    private List<SpotifyMatchResultModel> _results = new();
    private bool _isSearching = false;
    private string _errorMessage = "";
    #endregion

    #region Methods
    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(_sentence)) return;

        _isSearching = true;
        _errorMessage = "";
        _results = new();
        StateHasChanged();

        try
        {
            _results = await SpotifyService.MatchSentenceAsync(_sentence);

            if (_results.Count == 0)
                _errorMessage = "No results found. The Spotify proxy may not be configured yet.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }
    #endregion
}
