@page "/sts"
@inject SpotifyService SpotifyService

<PageTitle>Spotify That Sentence</PageTitle>

<div class="sts-root">
    <div class="sts-hero">
        <div class="sts-logo-row">
            <svg class="sts-spotify-icon" viewBox="0 0 24 24" fill="#1DB954" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
            <span class="sts-title">Spotify That Sentence</span>
        </div>
        <p class="sts-subtitle">Type a sentence — find a Spotify track for every word.</p>

        <div class="sts-search-row">
            <input class="sts-input"
                   @bind="_sentence"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   placeholder="e.g. we are the champions"
                   disabled="@_isSearching" />
            <button class="sts-btn @(_isSearching || string.IsNullOrWhiteSpace(_sentence) ? "sts-btn-disabled" : "")"
                    @onclick="Search"
                    disabled="@(_isSearching || string.IsNullOrWhiteSpace(_sentence))">
                @(_isSearching ? "Searching…" : "Find Tracks")
            </button>
        </div>

        @if (_isSearching)
        {
            <div class="sts-progress">
                <div class="sts-progress-bar"></div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="sts-error">@_errorMessage</div>
        }
    </div>

    @if (_results.Count > 0)
    {
        <div class="sts-results-section">
            <div class="sts-section-label">Results</div>
            <STSResultsComponent Results="_results" />
        </div>
    }
</div>

<style>
    .sts-root {
        min-height: 100vh;
        background: #121212;
        padding: 0 0 48px;
        font-family: 'Circular', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .sts-hero {
        background: linear-gradient(180deg, #1a3a1a 0%, #121212 100%);
        padding: 48px 32px 40px;
        max-width: 780px;
        margin: 0 auto;
    }

    .sts-logo-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 8px;
    }

    .sts-spotify-icon {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
    }

    .sts-title {
        font-size: 2rem;
        font-weight: 900;
        color: #fff;
        letter-spacing: -0.5px;
    }

    .sts-subtitle {
        color: #b3b3b3;
        font-size: 0.95rem;
        margin: 0 0 28px 44px;
    }

    .sts-search-row {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .sts-input {
        flex: 1;
        background: #2a2a2a;
        border: none;
        border-radius: 500px;
        padding: 14px 20px;
        color: #fff;
        font-size: 0.95rem;
        outline: none;
        transition: background 0.2s;
    }

    .sts-input:focus {
        background: #333;
    }

    .sts-input::placeholder {
        color: #6a6a6a;
    }

    .sts-input:disabled {
        opacity: 0.5;
    }

    .sts-btn {
        background: #1DB954;
        color: #000;
        font-weight: 700;
        font-size: 0.875rem;
        border: none;
        border-radius: 500px;
        padding: 14px 28px;
        cursor: pointer;
        white-space: nowrap;
        transition: transform 0.1s, background 0.2s;
        letter-spacing: 0.5px;
    }

    .sts-btn:hover:not(:disabled) {
        background: #1ed760;
        transform: scale(1.03);
    }

    .sts-btn-disabled, .sts-btn:disabled {
        background: #535353;
        color: #a7a7a7;
        cursor: not-allowed;
        transform: none;
    }

    .sts-progress {
        margin-top: 20px;
        height: 3px;
        background: #2a2a2a;
        border-radius: 3px;
        overflow: hidden;
    }

    .sts-progress-bar {
        height: 100%;
        background: #1DB954;
        border-radius: 3px;
        animation: sts-progress-anim 1.4s ease-in-out infinite;
    }

    @@keyframes sts-progress-anim {
        0% { width: 0%; margin-left: 0; }
        50% { width: 60%; margin-left: 20%; }
        100% { width: 0%; margin-left: 100%; }
    }

    .sts-error {
        margin-top: 16px;
        background: #3a1a1a;
        border-left: 3px solid #e91429;
        color: #ff6b6b;
        padding: 12px 16px;
        border-radius: 4px;
        font-size: 0.875rem;
    }

    .sts-results-section {
        max-width: 780px;
        margin: 0 auto;
        padding: 0 32px;
    }

    .sts-section-label {
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 16px;
    }
</style>

@code {
    #region Fields
    private string _sentence = "";
    private List<SpotifyMatchResultModel> _results = new();
    private bool _isSearching = false;
    private string _errorMessage = "";
    #endregion

    #region Methods
    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(_sentence)) return;

        _isSearching = true;
        _errorMessage = "";
        _results = new();
        StateHasChanged();

        try
        {
            _results = await SpotifyService.MatchSentenceAsync(_sentence);

            if (_results.Count == 0)
                _errorMessage = "No results found. The Spotify proxy may not be configured yet.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Search failed: {ex.Message}";
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Search();
    }
    #endregion
}
