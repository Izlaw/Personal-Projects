<div class="sts-results-scroll">
    @foreach (var result in Results)
    {
        <STSTrackCardComponent Result="result" />
    }
</div>

<style>
    .sts-results-scroll {
        display: flex;
        flex-direction: row;
        gap: 16px;
        overflow-x: auto;
        padding: 4px 4px 20px;
        align-items: flex-start;
        scrollbar-width: thin;
        scrollbar-color: #535353 transparent;
    }

    .sts-results-scroll::-webkit-scrollbar {
        height: 6px;
    }

    .sts-results-scroll::-webkit-scrollbar-track {
        background: transparent;
    }

    .sts-results-scroll::-webkit-scrollbar-thumb {
        background: #535353;
        border-radius: 3px;
    }
</style>

@code {
    [Parameter] public List<SpotifyMatchResultModel> Results { get; set; } = new();
}
