<div class="sts-row">
    @if (Result.IsMatched && Result.Track is { } track)
    {
        @if (!string.IsNullOrEmpty(track.AlbumArtUrl))
        {
            <img class="sts-art" src="@track.AlbumArtUrl" alt="@track.Name" />
        }
        else
        {
            <div class="sts-art sts-art-placeholder">
                <svg viewBox="0 0 24 24" fill="#535353" width="24" height="24"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg>
            </div>
        }
        <div class="sts-info">
            <a class="sts-track-name" href="@track.SpotifyUrl" target="_blank">@track.Name</a>
            <span class="sts-artist">@string.Join(", ", track.Artists)</span>
        </div>
    }
    else
    {
        <div class="sts-art sts-art-placeholder">
            <svg viewBox="0 0 24 24" fill="#535353" width="24" height="24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" style="display:none"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
        </div>
        <div class="sts-info">
            <span class="sts-no-phrase">"@Result.Word"</span>
            <span class="sts-no-match">No match found</span>
        </div>
    }
</div>

<style>
    .sts-row {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        gap: 12px;
        transition: background 0.15s;
        border-radius: 4px;
        cursor: default;
    }

    .sts-row:hover {
        background: #282828;
    }

    .sts-art {
        width: 48px;
        height: 48px;
        border-radius: 4px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .sts-art-placeholder {
        background: #282828;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sts-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .sts-track-name {
        color: #1DB954;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sts-track-name:hover {
        text-decoration: underline;
    }

    .sts-artist {
        color: #b3b3b3;
        font-size: 0.75rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sts-no-phrase {
        color: #b3b3b3;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .sts-no-match {
        color: #535353;
        font-size: 0.75rem;
    }
</style>

@code {
    [Parameter] public SpotifyMatchResultModel Result { get; set; } = new();
}
