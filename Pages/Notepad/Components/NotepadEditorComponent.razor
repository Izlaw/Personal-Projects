<div class="np-editor-container">
    @if (Tab is not null)
    {
        <textarea class="np-textarea"
                  value="@Tab.Content"
                  @oninput="@((e) => OnContentChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                  placeholder="Start typing..."
                  spellcheck="true"></textarea>
    }
    else
    {
        <div class="np-empty">
            <MudIcon Icon="@Icons.Material.Outlined.NoteAdd" Style="font-size:3rem; color:#d1d5db;" />
            <MudText Typo="Typo.body2" Style="color:#9ca3af; margin-top:8px;">No tab selected. Create one to start writing.</MudText>
        </div>
    }
</div>

<style>
    .np-editor-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        height: 100%;
    }

    .np-textarea {
        flex: 1;
        width: 100%;
        height: 100%;
        box-sizing: border-box;
        padding: 20px 28px;
        border: none;
        outline: none;
        font-size: 0.975rem;
        line-height: 1.75;
        color: #111827;
        background: #ffffff;
        resize: none;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .np-textarea::placeholder {
        color: #d1d5db;
    }

    .np-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #ffffff;
    }
</style>

@code {
    [Parameter] public NotepadTabModel? Tab { get; set; }
    [Parameter] public EventCallback<string> OnContentChanged { get; set; }
}
