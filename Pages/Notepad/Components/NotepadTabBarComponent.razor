@inject IJSRuntime JSRuntime

<MudList T="NotepadTabModel" Dense="true" Class="np-list" DisablePadding="true">
    @foreach (var tab in Tabs)
    {
        var isActive = tab.Key == ActiveTab?.Key;
        <MudListItem T="NotepadTabModel"
                     Class="@($"np-list-item {(isActive ? "np-list-item-active" : "")}")"
                     data-tab-key="@tab.Key"
                     OnClick="@(() => OnTabSelected.InvokeAsync(tab))">
            <div class="np-list-item-content">
                <MudIcon Icon="@Icons.Material.Outlined.Description"
                         Size="Size.Small"
                         Class="np-list-icon" />
                <span class="np-list-title" title="@tab.Title">@tab.Title</span>
                <span @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   Class="np-list-close"
                                   OnClick="@(() => OnCloseTab.InvokeAsync(tab))" />
                </span>
            </div>
        </MudListItem>
    }
</MudList>

<style>
    .np-list {
        padding: 4px 0 !important;
    }

    .np-list-item {
        border-radius: 0 !important;
        cursor: pointer;
        transition: background 0.1s;
        padding: 0 !important;
    }

    .np-list-item:hover {
        background: #f3f4f6 !important;
    }

    .np-list-item-active {
        background: #eff6ff !important;
        border-right: 2px solid #3b82f6;
    }

    .np-list-item-content {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 4px 6px 12px;
        width: 100%;
        min-width: 0;
    }

    .np-list-icon {
        flex-shrink: 0;
        color: #9ca3af !important;
    }

    .np-list-item-active .np-list-icon {
        color: #3b82f6 !important;
    }

    .np-list-title {
        flex: 1;
        font-size: 0.8rem;
        color: #374151;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        min-width: 0;
    }

    .np-list-item-active .np-list-title {
        color: #3b82f6;
        font-weight: 600;
    }

    .np-list-close {
        opacity: 0;
        flex-shrink: 0;
        transition: opacity 0.15s;
        width: 24px !important;
        height: 24px !important;
        color: #9ca3af !important;
    }

    .np-list-item:hover .np-list-close,
    .np-list-item-active .np-list-close {
        opacity: 1;
    }

    .np-list-close:hover {
        color: #ef4444 !important;
    }
</style>

@code {
    #region Parameters
    [Parameter] public List<NotepadTabModel> Tabs { get; set; } = new();
    [Parameter] public NotepadTabModel? ActiveTab { get; set; }
    [Parameter] public EventCallback<NotepadTabModel> OnTabSelected { get; set; }
    [Parameter] public EventCallback OnNewTab { get; set; }
    [Parameter] public EventCallback<NotepadTabModel> OnCloseTab { get; set; }
    [Parameter] public EventCallback<(string Key, int NewIndex)> OnReorderTab { get; set; }
    #endregion
}
