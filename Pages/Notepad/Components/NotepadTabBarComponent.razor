@inject IJSRuntime JSRuntime

<div id="notepad-tab-bar" class="notepad-tab-bar">
    @foreach (var tab in Tabs)
    {
        var isActive = tab.Key == ActiveTab?.Key;
        <div class="notepad-tab-chip @(isActive ? "active" : "")"
             data-tab-key="@tab.Key"
             @onclick="@(() => OnTabSelected.InvokeAsync(tab))">
            <span class="tab-title">@tab.Title</span>
            <span @onclick:stopPropagation="true">
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               Class="tab-close-btn"
                               OnClick="@(() => OnCloseTab.InvokeAsync(tab))" />
            </span>
        </div>
    }
    <MudIconButton Icon="@Icons.Material.Filled.Add"
                   Size="Size.Small"
                   Color="Color.Primary"
                   title="New Tab (Ctrl+N)"
                   OnClick="@(() => OnNewTab.InvokeAsync())" />
</div>

<style>
    .notepad-tab-bar {
        display: flex;
        align-items: center;
        gap: 4px;
        overflow-x: auto;
        padding: 8px 8px 0;
        background: #f5f5f5;
        border: 1px solid #e0e0e0;
        border-bottom: none;
        border-radius: 4px 4px 0 0;
        flex-wrap: nowrap;
    }
    .notepad-tab-chip {
        display: inline-flex;
        align-items: center;
        padding: 4px 4px 4px 10px;
        border-radius: 4px 4px 0 0;
        background: #e0e0e0;
        cursor: pointer;
        white-space: nowrap;
        font-size: 0.85rem;
        user-select: none;
        border: 1px solid #ccc;
        border-bottom: none;
        gap: 2px;
    }
    .notepad-tab-chip.active {
        background: #ffffff;
        border-color: #bbb;
        font-weight: 600;
    }
    .notepad-tab-chip:hover {
        background: #f0f0f0;
    }
    .notepad-tab-chip.active:hover {
        background: #ffffff;
    }
</style>

@code {
    #region Parameters
    [Parameter] public List<NotepadTabModel> Tabs { get; set; } = new();
    [Parameter] public NotepadTabModel? ActiveTab { get; set; }
    [Parameter] public EventCallback<NotepadTabModel> OnTabSelected { get; set; }
    [Parameter] public EventCallback OnNewTab { get; set; }
    [Parameter] public EventCallback<NotepadTabModel> OnCloseTab { get; set; }
    [Parameter] public EventCallback<(string Key, int NewIndex)> OnReorderTab { get; set; }
    #endregion
}
