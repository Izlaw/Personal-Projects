@page "/valentines"
@inject IJSRuntime JSRuntime
@inject AppThemeService AppTheme
@implements IAsyncDisposable

<PageTitle>Valentine's Card</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet" />

<div class="vp-wrapper">
    <div class="vp-card">
        @if (!_saidYes)
        {
            <p class="vp-text">Danni, will you be my Valentine? 💕</p>

            @if (_noClickCount > 0)
            {
                <p class="vp-subtext">Are you @(string.Concat(Enumerable.Repeat("really ", _noClickCount)))sure?</p>
            }

            <div class="vp-buttons">
                <button class="vp-btn vp-btn-yes" @onclick="SayYes">Yes</button>
                <button class="vp-btn vp-btn-no"
                        style="font-size: @(_noButtonSize.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))rem;"
                        @onclick="SayNo">
                    No
                </button>
            </div>
        }
        else
        {
            <p class="vp-text">FEBRUARY 14'S THE DATE, THERE'S NO ESCAPE! 🎉</p>
            @if (_noClickCount > 0)
            {
                <p class="vp-subtext">
                    KNEW YOU'D SAY YES! (eventually after being asked @_noClickCount time@(_noClickCount == 1 ? "" : "s"))
                </p>
            }
            <img src="images/cat.gif" alt="Happy cat" class="vp-gif" />
        }
    </div>
</div>

<style>
    .vp-wrapper {
        min-height: var(--page-h);
        background: #fbcfe8;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        font-family: 'Pacifico', cursive;
        overflow: hidden;
    }

    .vp-card {
        background: #ffffff;
        border: 4px solid #ef4444;
        border-radius: 12px;
        padding: 48px 64px;
        max-width: 580px;
        width: 100%;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        position: relative;
        z-index: 1;
    }

    .vp-text {
        font-size: 2rem;
        color: #dc2626;
        margin: 0 0 16px;
        line-height: 1.3;
    }

    .vp-subtext {
        font-size: 1rem;
        color: #6b7280;
        margin: 0 0 20px;
        font-family: sans-serif;
    }

    .vp-buttons {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin-top: 24px;
        flex-wrap: wrap;
    }

    .vp-btn {
        padding: 12px 32px;
        border: none;
        border-radius: 500px;
        font-size: 1rem;
        cursor: pointer;
        font-family: 'Pacifico', cursive;
        background: #ef4444;
        color: #ffffff;
        transition: transform 0.1s, background 0.15s;
    }

    .vp-btn:hover {
        transform: scale(1.08);
        background: #dc2626;
    }

    .vp-gif {
        max-width: 200px;
        border-radius: 12px;
        margin-top: 16px;
    }
</style>

@code {
    protected override void OnInitialized() => AppTheme.SetTheme("#e91e63");

    #region Fields
    private int _noClickCount = 0;
    private bool _saidYes = false;
    private double _noButtonSize = 1.0;
    #endregion

    #region Methods
    private async Task SayYes()
    {
        _saidYes = true;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("valentines.spawnHearts", 20);
    }

    private async Task SayNo()
    {
        _noClickCount++;
        _noButtonSize = Math.Max(0.6, 1.0 - _noClickCount * 0.05);

        if (_noClickCount >= 3)
            await JSRuntime.InvokeVoidAsync("valentines.spawnEmojis", Math.Min(_noClickCount, 8));

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        AppTheme.Reset();
        await JSRuntime.InvokeVoidAsync("valentines.stopHearts");
    }
    #endregion
}
