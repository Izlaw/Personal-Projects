@page "/"
@inject NavigationManager NavigationManager

<PageTitle>Personal Projects</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack AlignItems="AlignItems.Center" Class="mb-8">
        <MudText Typo="Typo.h3" Align="Align.Center"><b>Personal Projects</b></MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
            A collection of personal tools and games — all in one place.
        </MudText>
    </MudStack>

    <MudGrid Spacing="4" Justify="Justify.Center">

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Class="hub-card">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Daily Time Record</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Internship hours tracker</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Track daily login/logout times with automatic hour calculation.
                        Monitors progress toward the 600-hour target.
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/dtr" FullWidth="true">
                        Open
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Class="hub-card">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Secondary">
                            <MudIcon Icon="@Icons.Material.Filled.Note" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Online Notepad</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Cloud-synced multi-tab notes</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Multi-tab notepad with Supabase real-time sync. Supports drag-and-drop tab
                        reordering and Ctrl+S / Ctrl+N / Ctrl+W shortcuts.
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/notepad" FullWidth="true">
                        Open
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Class="hub-card">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Style="background-color: #e91e63;">
                            <MudIcon Icon="@Icons.Material.Filled.Favorite" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Valentine's Card</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">An interactive love letter</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        A classic "Will you be my Valentine?" experience — complete with
                        escalating guilt trips, falling emojis, and a very happy cat.
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Style="background-color: #e91e63; color: white;" Href="/valentines" FullWidth="true">
                        Open
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Class="hub-card">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Style="background-color: #1db954;">
                            <MudIcon Icon="@Icons.Material.Filled.MusicNote" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Spotify That Sentence</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Turn words into a playlist</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        Type a sentence and find Spotify tracks matching each word or phrase.
                        Greedily matches the longest possible phrases first.
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Style="background-color: #1db954; color: white;" Href="/sts" FullWidth="true">
                        Open
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

    </MudGrid>
</MudContainer>

<style>
    .hub-card {
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hub-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15) !important;
    }
</style>
