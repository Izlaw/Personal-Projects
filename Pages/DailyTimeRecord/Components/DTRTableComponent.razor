<div class="dtrt-wrap">
    <MudTable Items="Entries" Dense="true" Hover="true" Striped="true"
              FixedHeader="true" Height="500px" Elevation="0">
        <HeaderContent>
            <MudTh>Date</MudTh>
            <MudTh>Morning Login</MudTh>
            <MudTh>Morning Logout</MudTh>
            <MudTh>Afternoon Login</MudTh>
            <MudTh>Afternoon Logout</MudTh>
            <MudTh>Hours</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <DTRRowComponent Entry="context"
                             OnChanged="@((e) => OnEntryChanged.InvokeAsync(e))"
                             OnDelete="@((key) => OnDeleteEntry.InvokeAsync(key))" />
        </RowTemplate>
    </MudTable>
</div>

<MudButton StartIcon="@Icons.Material.Filled.Add"
           Variant="Variant.Text"
           Color="Color.Primary"
           FullWidth="true"
           Class="mt-0"
           Style="border-top: 1px solid #e5e7eb; border-radius: 0;"
           OnClick="@(() => OnAddEntry.InvokeAsync())">
    Add New Record
</MudButton>

<style>
    .dtrt-wrap {
        overflow-x: auto;
    }
</style>

@code {
    #region Parameters
    [Parameter] public List<DtrEntryModel> Entries { get; set; } = new();
    [Parameter] public EventCallback<DtrEntryModel> OnEntryChanged { get; set; }
    [Parameter] public EventCallback<string> OnDeleteEntry { get; set; }
    [Parameter] public EventCallback OnAddEntry { get; set; }
    #endregion
}
